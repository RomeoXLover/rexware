# Copy to a .env file next to docker-compose.yml and fill in.
# Easiest: run ./setup.sh — it creates .env and auto-generates the
# secrets below (RUNNER_TOKEN, AUTH_SECRET, CRYPTAPI_CALLBACK_SECRET).
# docker compose automatically reads ".env" in the compose directory.

# Domain the app is served on (your HOST nginx proxies to it).
DOMAIN=skyutils.xyz

# Loopback port the app container is exposed on (host nginx proxies here).
APP_PORT=3000

# Public URL of the site (used for OAuth + payment callbacks).
APP_BASE_URL=https://skyutils.xyz

# --- PostgreSQL (the `db` service in docker-compose) ------------------------
# POSTGRES_PASSWORD is required. User/DB default to "antecore" if left blank.
# The app builds DATABASE_URL automatically from these in docker-compose.yml.
POSTGRES_USER=antecore
POSTGRES_DB=antecore
POSTGRES_PASSWORD=

# --- Auto-generated secrets (generate with: openssl rand -hex 32) -----------
# Shared secret the bot containers use to authenticate to /api/runner/callback.
RUNNER_TOKEN=
# Session/JWT signing secret.
AUTH_SECRET=
# HMAC secret for verifying CryptAPI payment callbacks.
CRYPTAPI_CALLBACK_SECRET=

# --- Discord (fill these in yourself) ---------------------------------------
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=https://skyutils.xyz/api/auth/discord/callback
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=

# Global Chat — Discord channel that mirrors web global chat via webhooks.
# When set, new users get a personal webhook in this channel on signup,
# allowing them to post messages FROM the web TO Discord as themselves.
DISCORD_GLOBAL_CHAT_CHANNEL_ID=

# --- Payments (CryptAPI — your own destination wallets) ---------------------
CRYPTAPI_LTC_ADDRESS=
CRYPTAPI_BTC_ADDRESS=

# --- Anti-VPN (optional IP reputation provider) -----------------------------
# Leave blank to disable provider lookups (Tor is still blocked via Cloudflare).
# Supported: proxycheck (free tier 1000/day). Get a key at proxycheck.io.
VPN_PROVIDER=
VPN_API_KEY=

# NOTE: TLS + the public reverse proxy are handled by the nginx ALREADY on this
# VPS — not by this stack. See nginx/skyutils.conf (or run `./setup.sh nginx`)
# for a server block, then terminate HTTPS on the host:
#   sudo certbot --nginx -d skyutils.xyz -d www.skyutils.xyz
